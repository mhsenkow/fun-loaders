{
  "name": "fun-loaders",
  "version": "0.1.0",
  "description": "A library of complex, canvas-based loading animations",
  "type": "module",
  "main": "./dist/fun-loaders.umd.cjs",
  "module": "./dist/fun-loaders.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fun-loaders.js",
      "require": "./dist/fun-loaders.umd.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.lib.json && vite build --config vite.lib.config.ts",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview",
    "preview:demo": "vite preview --config vite.demo.config.ts --outDir demo-dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4"
  }
}
